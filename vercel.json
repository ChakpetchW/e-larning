{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "elearning-api/src/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "elearning-api/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/elearning-webapp/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/elearning-webapp/index.html"
    }
  ]
}